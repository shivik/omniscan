{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.20.0",
          "rules": [
            {
              "id": "py/command-line-injection",
              "name": "py/command-line-injection",
              "shortDescription": {"text": "Uncontrolled command line"},
              "properties": {"security-severity": "9.8", "tags": ["security", "external/cwe/cwe-078"]}
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "py/command-line-injection",
          "level": "error",
          "message": {"text": "This command depends on a user-provided value."},
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "/src/app/handlers.py"},
                "region": {"startLine": 42}
              }
            }
          ]
        }
      ]
    }
  ]
}
