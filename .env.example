# Copy to .env. Fill real secrets via the secret manager, NOT this file.
# Only non-sensitive config + secret *references* belong here.

OMNISCAN_ENV=dev
OMNISCAN_DEBUG=true

# Datastore — dev default is zero-infra SQLite. Prod: postgresql+asyncpg://...
OMNISCAN_DATABASE_URL=sqlite+aiosqlite:///./omniscan.db

# Job execution — "inprocess" (dev) | "arq" (prod, needs Redis)
OMNISCAN_JOB_BACKEND=inprocess
OMNISCAN_REDIS_URL=redis://localhost:6379/0

# Object store for raw output + reports — file:// (dev) | s3://bucket/prefix (prod/MinIO)
OMNISCAN_OBJECT_STORE_URL=file://./var/objects
# For S3/MinIO (when OMNISCAN_OBJECT_STORE_URL=s3://...) — needs the `prod` extra (boto3):
# OMNISCAN_S3_ENDPOINT=http://localhost:9000     # set for MinIO; leave unset for AWS S3
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio123
# AWS_REGION=us-east-1

# Secrets backend — "env" (dev) | "vault" (prod, needs the `prod` extra: hvac)
OMNISCAN_SECRETS_BACKEND=env
# For Vault (when OMNISCAN_SECRETS_BACKEND=vault):
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=dev-root

# Dev bootstrap admin token (prod issues per-user tokens via an IdP)
OMNISCAN_BOOTSTRAP_ADMIN_TOKEN=dev-admin-token

# Example resolved secret for the env backend (vault://omniscan/acme/login):
# OMNISCAN_SECRET_ACME_LOGIN=...
